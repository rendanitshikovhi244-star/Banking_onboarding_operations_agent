# Copy this file to banking_agent/.env and fill in your credentials.
# NEVER commit banking_agent/.env — it is excluded by .gitignore.

# --- HuggingFace (free, good for testing) ---
HUGGINGFACE_API_KEY=hf_your_key_here

# Model tier assignments — spread across 3 models to stay within per-model quotas
# FAST  (SmolLM2-1.7B) : IntakeAgent, DocumentAgent  — structured JSON extraction + rule following
# MID   (Mistral-7B)   : IdentityAgent, AMLAgent, AuditAgent — rule-following, pattern matching
# MAIN  (Qwen2.5-7B)   : RiskAgent, OnboardingAssistant — nuanced reasoning + conversation
HF_MODEL_FAST=huggingface/HuggingFaceTB/SmolLM2-1.7B-Instruct
HF_MODEL_MID=huggingface/mistralai/Mistral-7B-Instruct
HF_MODEL_MAIN=huggingface/Qwen/Qwen2.5-7B-Instruct

# --- Google Gemini (option: set in model_config.py as DEFAULT_MODEL = "gemini-2.5-flash") ---
# GOOGLE_API_KEY=your_key_from_aistudio.google.com
# GOOGLE_GENAI_USE_VERTEXAI=FALSE

# --- Infrastructure ---
REDIS_URL=redis://localhost:6379/0
SESSION_DB_URL=sqlite+aiosqlite:///./banking_sessions.db

# --- External screening APIs (mocked in this implementation) ---
# PEP_SCREENING_API_KEY=your_pep_api_key
# SANCTIONS_API_KEY=your_sanctions_api_key
# ADVERSE_MEDIA_API_KEY=your_adverse_media_api_key
